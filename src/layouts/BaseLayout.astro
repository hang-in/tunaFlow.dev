---
export interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'ko';
}

const {
  title = 'tunaFlow - A family of focused, open-source dev tools',
  description = 'tunaFlow is both a desktop AI coding client and the brand for a family of focused dev tools from hang-in - AI agents on one side, real-time graphics and physics on the other.',
  lang = 'en',
} = Astro.props;

import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import ParallaxBg from '~/components/ParallaxBg.astro';
import { getEntry } from 'astro:content';

const site = await getEntry('site', 'config');
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#050508" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <ParallaxBg />
    <Header />
    <slot />
    <Footer site={site?.data} />
  </body>
</html>
