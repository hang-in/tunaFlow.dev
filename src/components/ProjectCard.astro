---
import type { CollectionEntry } from 'astro:content';
import { getMetadata } from '~/lib/metadata';
import Icon from './Icon.astro';

export interface Props {
  project: CollectionEntry<'projects'>['data'];
  variant?: 'default' | 'featured';
}

const { project, variant = 'default' } = Astro.props;
const live = await getMetadata(project.sources);
const isAi = project.track === 'ai-dev';
const accent = isAi ? 'var(--accent)' : 'var(--accent-2)';
const hasSite = !!project.sources.site;
const hostIcon = project.sources.host === 'github' ? 'github' : 'external';
const statusIcon = {
  beta: 'sparkles',
  stable: 'star',
  wip: 'code',
  archived: 'clock',
} as const;
---
<article
  class="card"
  data-variant={variant}
  data-track={project.track}
  style={`--card-accent: ${accent}`}
>
  <header>
    <h3>
      {hasSite ? (
        <a href={project.sources.site} target="_blank" rel="noopener">{project.name}</a>
      ) : (
        <a href={project.sources.repo} target="_blank" rel="noopener">{project.name}</a>
      )}
    </h3>
    <span class={`status status-${project.status}`}>
      <Icon name={statusIcon[project.status]} size={12} />
      {project.status}
    </span>
  </header>
  <p class="tagline">{project.tagline}</p>
  <p class="description">{project.description}</p>
  <footer>
    <span class="lang">
      <Icon name="code" size={12} />
      {project.language}
    </span>
    <span class="meta">
      {live.stars !== null && (
        <span class="badge" title="stars">
          <Icon name="star" size={12} />
          {live.stars}
        </span>
      )}
      {live.pushedAt && (
        <span class="badge" title={`last push: ${live.pushedAt}`}>
          <Icon name="clock" size={12} />
          {new Date(live.pushedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
        </span>
      )}
    </span>
  </footer>
  <nav class="links">
    {hasSite && (
      <a href={project.sources.site} target="_blank" rel="noopener">
        <Icon name="external" size={12} />
        Live
      </a>
    )}
    <a href={project.sources.repo} target="_blank" rel="noopener">
      <Icon name={hostIcon} size={12} />
      Repo
    </a>
  </nav>
</article>

<style>
  .card {
    --card-accent: var(--accent);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(8px);
  }
  .card:hover {
    border-color: var(--card-accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }
  .card[data-variant='featured'] {
    border-color: var(--card-accent);
    background:
      linear-gradient(180deg, var(--card-bg-2) 0%, var(--card-bg) 100%);
  }
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  h3 {
    margin: 0;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }
  h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--card-accent);
    text-decoration: none;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: #333;
    color: #ccc;
    white-space: nowrap;
  }
  .status-beta { background: #4a3a00; color: #f6c453; }
  .status-stable { background: #003a2a; color: #7be3a5; }
  .status-wip { background: #2a2a2a; color: #aaa; }
  .status-archived { background: #2a1a1a; color: #c98c8c; }
  .tagline {
    margin: 0;
    font-weight: 500;
    color: #e8e8e8;
  }
  .description {
    margin: 0;
    color: #999;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #777;
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .meta {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--border);
    color: #aaa;
  }
  .links {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--card-accent);
  }
</style>
