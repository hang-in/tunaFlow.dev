---
import type { CollectionEntry } from 'astro:content';
import { getMetadata } from '~/lib/metadata';
import Icon from './Icon.astro';

export interface Props {
  project: CollectionEntry<'projects'>['data'];
  variant?: 'default' | 'featured';
}

const { project, variant = 'default' } = Astro.props;
const live = await getMetadata(project.sources);
const isAi = project.track === 'ai-dev';
const accent = isAi ? 'var(--accent)' : 'var(--accent-2)';
const hasSite = !!project.sources.site;
const hostIcon = project.sources.host === 'github' ? 'github' : 'external';
const statusIcon = {
  beta: 'sparkles',
  stable: 'star',
  wip: 'code',
  archived: 'clock',
} as const;

const osLabels: Record<string, string> = {
  macos: 'macOS',
  windows: 'Windows',
  linux: 'Linux',
  ios: 'iOS',
  android: 'Android',
  web: 'Web',
  all: 'All platforms',
};
---
<article
  class="card"
  data-variant={variant}
  data-track={project.track}
  style={`--card-accent: ${accent}`}
>
  <header>
    <h3>
      {hasSite ? (
        <a href={project.sources.site} target="_blank" rel="noopener">{project.name}</a>
      ) : (
        <a href={project.sources.repo} target="_blank" rel="noopener">{project.name}</a>
      )}
    </h3>
    <span class="flat-badge" data-scheme={project.status}>
      <Icon name={statusIcon[project.status]} size={12} />
      {project.status}
    </span>
  </header>
  <p class="tagline">{project.tagline}</p>
  <p class="description">{project.description}</p>
  <footer>
    <span class="badges">
      <span class="flat-badge" data-scheme="lang">
        <Icon name="code" size={12} />
        {project.language}
      </span>
      {project.os.length > 0 && (
        <span class="flat-badge-group">
          {project.os.map((o) => (
            <span
              class="flat-badge flat-badge-two-tone"
              data-scheme={o === 'web' ? 'web' : 'os'}
              title={osLabels[o] || o}
            >
              <span class="flat-badge-label">OS</span>
              <span class="flat-badge-value">{osLabels[o] || o}</span>
            </span>
          ))}
        </span>
      )}
    </span>
    <span class="badges">
      {live.stars !== null && (
        <span class="flat-badge" data-scheme="stars" title="stars">
          <Icon name="star" size={12} />
          {live.stars}
        </span>
      )}
      {live.pushedAt && (
        <span class="flat-badge" data-scheme="updated" title={`last push: ${live.pushedAt}`}>
          <Icon name="clock" size={12} />
          {new Date(live.pushedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
        </span>
      )}
    </span>
  </footer>
  <nav class="links">
    {hasSite && (
      <a href={project.sources.site} target="_blank" rel="noopener">
        <Icon name="external" size={12} />
        Live
      </a>
    )}
    <a href={project.sources.repo} target="_blank" rel="noopener">
      <Icon name={hostIcon} size={12} />
      Repo
    </a>
  </nav>
</article>

<style>
  .card {
    --card-accent: var(--accent);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    backdrop-filter: blur(8px);
  }
  .card:hover {
    border-color: var(--card-accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }
  .card[data-variant='featured'] {
    border-color: var(--card-accent);
    background:
      linear-gradient(180deg, var(--card-bg-2) 0%, var(--card-bg) 100%);
  }
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  h3 {
    margin: 0;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }
  h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--card-accent);
    text-decoration: none;
  }

  /* Flat badge system */
  .flat-badge {
    --fb-bg: #27272a;
    --fb-fg: #d4d4d8;
    --fb-border: #3f3f46;
    --fb-icon: #a1a1aa;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 20px;
    padding: 0 0.5rem;
    border-radius: 4px;
    background: var(--fb-bg);
    color: var(--fb-fg);
    border: 1px solid var(--fb-border);
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .flat-badge svg {
    color: var(--fb-icon);
    flex-shrink: 0;
  }

  /* Two-tone variant: left label, right value */
  .flat-badge.flat-badge-two-tone {
    padding: 0;
    overflow: hidden;
    border: none;
    background: transparent;
  }
  .flat-badge.flat-badge-two-tone .flat-badge-label,
  .flat-badge.flat-badge-two-tone .flat-badge-value {
    display: inline-flex;
    align-items: center;
    height: 100%;
    padding: 0 0.4rem;
  }
  .flat-badge.flat-badge-two-tone .flat-badge-label {
    background: var(--fb-border);
    color: var(--fb-icon);
    font-weight: 700;
  }
  .flat-badge.flat-badge-two-tone .flat-badge-value {
    background: var(--fb-bg);
    color: var(--fb-fg);
    border: 1px solid var(--fb-border);
    border-left: none;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
  }

  /* Color schemes */
  .flat-badge[data-scheme='stable'] {
    --fb-bg: rgba(34, 197, 94, 0.12);
    --fb-fg: #86efac;
    --fb-border: rgba(34, 197, 94, 0.35);
    --fb-icon: #22c55e;
  }
  .flat-badge[data-scheme='beta'] {
    --fb-bg: rgba(245, 158, 11, 0.12);
    --fb-fg: #fde68a;
    --fb-border: rgba(245, 158, 11, 0.35);
    --fb-icon: #f59e0b;
  }
  .flat-badge[data-scheme='wip'] {
    --fb-bg: rgba(148, 163, 184, 0.12);
    --fb-fg: #e2e8f0;
    --fb-border: rgba(148, 163, 184, 0.35);
    --fb-icon: #94a3b8;
  }
  .flat-badge[data-scheme='archived'] {
    --fb-bg: rgba(244, 63, 94, 0.10);
    --fb-fg: #fecdd3;
    --fb-border: rgba(244, 63, 94, 0.30);
    --fb-icon: #f43f5e;
  }
  .flat-badge[data-scheme='lang'] {
    --fb-bg: rgba(124, 58, 237, 0.12);
    --fb-fg: #ddd6fe;
    --fb-border: rgba(124, 58, 237, 0.30);
    --fb-icon: #8b5cf6;
  }
  .flat-badge[data-scheme='os'] {
    --fb-bg: rgba(37, 99, 235, 0.12);
    --fb-fg: #bfdbfe;
    --fb-border: rgba(37, 99, 235, 0.30);
    --fb-icon: #3b82f6;
  }
  .flat-badge[data-scheme='web'] {
    --fb-bg: rgba(236, 72, 153, 0.12);
    --fb-fg: #fbcfe8;
    --fb-border: rgba(236, 72, 153, 0.30);
    --fb-icon: #ec4899;
  }
  .flat-badge[data-scheme='stars'] {
    --fb-bg: rgba(250, 204, 21, 0.12);
    --fb-fg: #fef08a;
    --fb-border: rgba(250, 204, 21, 0.30);
    --fb-icon: #facc15;
  }
  .flat-badge[data-scheme='updated'] {
    --fb-bg: rgba(100, 116, 139, 0.15);
    --fb-fg: #cbd5e1;
    --fb-border: rgba(100, 116, 139, 0.30);
    --fb-icon: #94a3b8;
  }

  .flat-badge-group {
    display: inline-flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .badges {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tagline {
    margin: 0;
    font-weight: 500;
    color: #e8e8e8;
  }
  .description {
    margin: 0;
    color: #999;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #777;
  }
  .links {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--card-accent);
  }
</style>
