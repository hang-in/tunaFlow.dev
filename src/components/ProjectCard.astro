---
import type { CollectionEntry } from 'astro:content';
import { getMetadata } from '~/lib/metadata';

export interface Props {
  project: CollectionEntry<'projects'>['data'];
  variant?: 'default' | 'featured';
}

const { project, variant = 'default' } = Astro.props;
const live = await getMetadata(project.sources);
const isAi = project.track === 'ai-dev';
const isShader = project.track === 'shader-physics';
const accent = isAi ? 'var(--accent)' : 'var(--accent-2)';
const hasSite = !!project.sources.site;
---
<article
  class="card"
  data-variant={variant}
  data-track={project.track}
  style={`--card-accent: ${accent}`}
>
  <header>
    <h3>
      {hasSite ? (
        <a href={project.sources.site} target="_blank" rel="noopener">{project.name}</a>
      ) : (
        <a href={project.sources.repo} target="_blank" rel="noopener">{project.name}</a>
      )}
    </h3>
    <span class={`status status-${project.status}`}>{project.status}</span>
  </header>
  <p class="tagline">{project.tagline}</p>
  <p class="description">{project.description}</p>
  <footer>
    <span class="lang">{project.language}</span>
    <span class="meta">
      {live.stars !== null && <span title="stars">★ {live.stars}</span>}
      {live.pushedAt && (
        <span title={`last push: ${live.pushedAt}`}>
          · {new Date(live.pushedAt).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
        </span>
      )}
    </span>
  </footer>
  <nav class="links">
    {hasSite && <a href={project.sources.site} target="_blank" rel="noopener">Live →</a>}
    <a href={project.sources.repo} target="_blank" rel="noopener">Repo →</a>
  </nav>
</article>

<style>
  .card {
    --card-accent: var(--accent);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.15s, transform 0.15s;
  }
  .card:hover {
    border-color: var(--card-accent);
    transform: translateY(-2px);
  }
  .card[data-variant='featured'] {
    border-color: var(--card-accent);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--card-accent) 12%, var(--card-bg)) 0%, var(--card-bg) 100%);
  }
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  h3 {
    margin: 0;
    font-size: 1.2rem;
  }
  h3 a {
    color: var(--fg);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--card-accent);
    text-decoration: none;
  }
  .status {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: #333;
    color: #ccc;
    white-space: nowrap;
  }
  .status-beta { background: #4a3a00; color: #f6c453; }
  .status-stable { background: #003a2a; color: #7be3a5; }
  .status-wip { background: #2a2a2a; color: #aaa; }
  .status-archived { background: #2a1a1a; color: #c98c8c; }
  .tagline {
    margin: 0;
    font-weight: 500;
    color: #e8e8e8;
  }
  .description {
    margin: 0;
    color: #999;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: #777;
  }
  .meta { display: flex; gap: 0.4rem; }
  .links {
    display: flex;
    gap: 0.75rem;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .links a {
    color: var(--card-accent);
  }
</style>
