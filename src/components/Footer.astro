---
import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

export interface Props {
  site?: CollectionEntry<'site'>['data'];
}
const { site } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer reveal">
  <div class="inner">
    <div class="brand-line">
      <strong>tunaFlow</strong> - a family of focused, open-source dev tools by
      {site?.links?.github
        ? <a href={site.links.github} target="_blank" rel="noopener">hang-in</a>
        : 'hang-in'
      }.
    </div>
    <div class="links">
      {site?.links?.github && (
        <a href={site.links.github} target="_blank" rel="noopener">
          <Icon name="github" size={16} />
          GitHub
        </a>
      )}
      <span class="muted"><Icon name="sparkles" size={12} /> © {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }
  .inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .brand-line { display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
  .links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
  }
  .links a:hover { color: var(--fg); text-decoration: none; }
  .muted {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--muted);
  }
</style>
