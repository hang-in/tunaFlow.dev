---
import ProjectCard from './ProjectCard.astro';
import Reveal from './Reveal.astro';
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';
import type { IconName } from './Icon.astro';

export interface Props {
  track: 'ai-dev' | 'shader-physics';
  heading: string;
  lede: string;
  featuredSlugs: string[];
  allInTrack: CollectionEntry<'projects'>['data'][];
  icon?: IconName;
}

const { track, heading, lede, featuredSlugs, allInTrack, icon } = Astro.props;

const featured = featuredSlugs
  .map((slug) => allInTrack.find((p) => p.slug === slug))
  .filter((p): p is CollectionEntry<'projects'>['data'] => !!p);

const headliner = featured[0];
const runnerUp = featured[1];
const tail = allInTrack
  .filter((p) => !featuredSlugs.includes(p.slug))
  .sort((a, b) => a.order - b.order || a.slug.localeCompare(b.slug));
---
<section class="track" data-track={track}>
  <Reveal>
    <header class="track-header">
      <p class="eyebrow">
        {icon && <span class="eyebrow-icon"><Icon name={icon} size={14} /></span>}
        Track
      </p>
      <h2>{heading}</h2>
      <p class="lede">{lede}</p>
    </header>
  </Reveal>

  {headliner && (
    <div class="headliner">
      <div class="reveal">
        <ProjectCard project={headliner} variant="featured" />
      </div>
      {runnerUp && (
        <div class="reveal">
          <ProjectCard project={runnerUp} variant="featured" />
        </div>
      )}
    </div>
  )}

  {tail.length > 0 && (
    <div class="grid">
      {tail.map((p, i) => (
        <div class="reveal" style={`transition-delay: ${(i % 3) * 80}ms`}>
          <ProjectCard project={p} />
        </div>
      ))}
    </div>
  )}
</section>

<style>
  .track {
    margin: 0;
  }
  .track-header {
    margin-bottom: 2rem;
    padding-top: 2rem;
  }
  .track-header h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .track-header .lede {
    color: var(--muted);
    margin: 0;
    max-width: 60ch;
    font-size: 1.05rem;
  }
  .eyebrow-icon {
    display: inline-flex;
    vertical-align: middle;
    margin-right: 0.35rem;
    color: var(--accent-2);
  }
  .headliner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: stretch;
  }
  .headliner :global(article) {
    height: 100%;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    align-items: stretch;
  }
  .grid :global(article) {
    height: 100%;
  }
</style>
