---
import BaseLayout from '~/layouts/BaseLayout.astro';
import TrackHeadline from '~/components/TrackHeadline.astro';
import Reveal from '~/components/Reveal.astro';
import Icon from '~/components/Icon.astro';
import { getCollection, getEntry } from 'astro:content';

const site = await getEntry('site', 'config');
if (!site) throw new Error('site/config.json missing');

const all = (await getCollection('projects')).map((e) => e.data);
const visible = all.filter((p) => !p.hidden);

const tracks = ['ai-dev', 'shader-physics'] as const;
const byTrack = Object.fromEntries(
  tracks.map((t) => [t, visible.filter((p) => p.track === t).sort((a, b) => a.order - b.order || a.slug.localeCompare(b.slug))]),
);

const trackIcon: Record<typeof tracks[number], 'sparkles' | 'orbit'> = {
  'ai-dev': 'sparkles',
  'shader-physics': 'orbit',
};
---
<BaseLayout
  title={site.data.title}
  description={site.data.description}
>
  <main>
    <section class="hero hero-scale">
      <Reveal delay={0}>
        <p class="eyebrow">
          <span class="eyebrow-icon"><Icon name="sparkles" size={14} /></span>
          {site.data.eyebrow}
        </p>
      </Reveal>
      <Reveal delay={80}>
        <h1>
          <span class="brand">tunaFlow</span> is a product - and a family.
        </h1>
      </Reveal>
      <Reveal delay={160}>
        <p class="lede">
          A small set of focused, open-source dev tools built by
          <a href={site.data.links.github} target="_blank" rel="noopener">hang-in</a>.
          On one track, tools for working with coding agents. On the other, real-time
          graphics and physics. Both share a name, an aesthetic, and a refusal to bloat.
        </p>
      </Reveal>
      <Reveal delay={240}>
        <div class="cta">
          <a class="btn primary" href="/projects">
            Browse the family
            <Icon name="arrow-right" size={16} />
          </a>
          <a class="btn" href="https://github.com/hang-in/tunaFlow" target="_blank" rel="noopener">
            <Icon name="github" size={16} />
            Get tunaFlow
          </a>
        </div>
      </Reveal>
      <div class="scroll-hint reveal">
        <Icon name="chevron-down" size={20} />
        <span>Scroll</span>
      </div>
    </section>

    <section class="tracks">
      {tracks.map((t) => (
        <TrackHeadline
          track={t}
          heading={site.data.tracks[t].heading}
          lede={site.data.tracks[t].lede}
          featuredSlugs={site.data.featured[t]}
          allInTrack={byTrack[t]}
          icon={trackIcon[t]}
        />
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
    padding-top: 4rem;
    position: relative;
    z-index: 1;
  }
  .hero h1 {
    font-size: clamp(2.8rem, 7vw, 5rem);
    margin: 0 0 1.25rem;
    letter-spacing: -0.03em;
    line-height: 1.05;
    max-width: 900px;
  }
  .brand {
    color: var(--accent);
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .lede {
    max-width: 620px;
    color: #b0b0b8;
    font-size: 1.15rem;
    margin: 0 0 2rem;
  }
  .lede a { color: var(--accent); }
  .cta { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .cta .btn { display: inline-flex; align-items: center; gap: 0.4rem; }
  .tracks {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }
  .eyebrow-icon {
    display: inline-flex;
    vertical-align: middle;
    margin-right: 0.35rem;
    color: var(--accent-2);
  }
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--muted);
    font-size: 0.8rem;
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint { animation: none; }
  }
</style>
