---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('projects')).map((e) => e.data);
const visible = all.filter((p) => !p.hidden);
const sorted = visible.sort((a, b) => a.order - b.order || a.slug.localeCompare(b.slug));
---
<BaseLayout
  title="Projects — tunaFlow"
  description="All projects in the tunaFlow family. AI dev tools and real-time graphics & physics."
>
  <main>
    <header class="page-header">
      <p class="eyebrow">The family</p>
      <h1>All projects</h1>
      <p class="lede">Sorted by track, then display order. Hidden entries are reachable by direct URL only.</p>
    </header>

    <section class="group">
      <h2>AI dev</h2>
      <div class="grid">
        {sorted.filter((p) => p.track === 'ai-dev').map((p) => <ProjectCard project={p} />)}
      </div>
    </section>

    <section class="group">
      <h2>Real-time graphics & physics</h2>
      <div class="grid">
        {sorted.filter((p) => p.track === 'shader-physics').map((p) => <ProjectCard project={p} />)}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .page-header { margin: 2rem 0 3rem; }
  .page-header h1 { font-size: 2.5rem; margin: 0 0 0.75rem; }
  .lede { color: var(--muted); margin: 0; }
  .group { margin: 3rem 0; }
  .group h2 {
    font-size: 1.4rem;
    margin: 0 0 1rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
</style>
